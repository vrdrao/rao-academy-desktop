#!/bin/sh
# Rao Academy pre-push hook. TWO gates, in order:
#
#   1. HISTORY GUARD (original): history is append-only — see CLAUDE.md "NEVER
#      REWRITE HISTORY". Blocks any non-fast-forward (force) push that would
#      overwrite remote history.
#
#   2. FULL SUITE GATE (BRIEF-PRECOMMIT-SPEED, 2026-07-18): commits pass only a
#      fast subset at commit time, so THIS is where the safety invariant lives —
#      no commit reaches the remote without the COMPLETE `npm test` green on
#      this exact tree. Takes ~12-15 min. Do not abort it mid-run (WORKFLOW.md).
#      NEVER bypass with --no-verify — forbidden (CLAUDE.md, THE ONE RULE).

pushing=0

while read local_ref local_sha remote_ref remote_sha; do
  # local all-zero  = branch deletion       -> nothing being overwritten with history
  # remote all-zero = brand-new branch      -> nothing on the remote to overwrite
  case "$local_sha"  in *[!0]*) : ;; *) continue ;; esac
  pushing=1
  case "$remote_sha" in *[!0]*) : ;; *) continue ;; esac

  # If the remote commit is NOT an ancestor of what we're pushing, this push would
  # discard/rewrite commits already on the remote. That is a force push. Block it.
  if ! git merge-base --is-ancestor "$remote_sha" "$local_sha"; then
    echo ""
    echo "################################################################"
    echo "#                                                              #"
    echo "#   ⛔  FORCE / HISTORY-REWRITE PUSH BLOCKED                   #"
    echo "#                                                              #"
    echo "#   This push would overwrite commits already on GitHub.       #"
    echo "#   History here is APPEND-ONLY (CLAUDE.md: NEVER REWRITE      #"
    echo "#   HISTORY). Nothing was pushed.                              #"
    echo "#                                                              #"
    echo "#   Ref: $remote_ref"
    echo "#                                                              #"
    echo "#   If you genuinely need this, talk to Venkat first.          #"
    echo "#                                                              #"
    echo "################################################################"
    exit 1
  fi
done

# Nothing with content being pushed (e.g. only branch deletions) -> no suite run.
[ "$pushing" -eq 1 ] || exit 0

echo ""
echo "pre-push: running the FULL npm test before anything leaves this machine."
echo "pre-push: this takes ~12-15 minutes. Do NOT abort it mid-run (WORKFLOW.md)."
echo ""

npm test
status=$?

if [ "$status" -ne 0 ]; then
  echo ""
  echo "################################################################"
  echo "#                                                              #"
  echo "#   ❌  FULL SUITE FAILED — PUSH BLOCKED                       #"
  echo "#                                                              #"
  echo "#   Nothing was pushed. Fix the failure and push again.        #"
  echo "#   Do NOT bypass with --no-verify (forbidden, CLAUDE.md).     #"
  echo "#                                                              #"
  echo "################################################################"
  exit 1
fi

echo ""
echo "✅ pre-push: full suite green — pushing."
exit 0
